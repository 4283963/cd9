# 服务端口
PORT=3001

# 前端地址（用于 CORS），多个地址用逗号分隔
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# 运行模式: mysql | memory
DB_MODE=memory

# MySQL 数据库配置（当 DB_MODE=mysql 时使用）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=tunnel_digital_twin

# WebSocket 配置
WS_PORT=5174

# 模拟数据生成器配置
MOCK_ENABLED=true
MOCK_INTERVAL=1000

# 坐标系统配置
COORDINATE_ORIGIN_LAT=30.0
COORDINATE_ORIGIN_LNG=114.0
COORDINATE_SCALE=1.0
